# Port the Node.js server listens on
PORT=3000

# Your app's public URL (for reference; no CORS issues since all requests are server-side)
APP_URL=http://localhost:3000

# Cache TTL in seconds for episode lists and metadata (default: 15 minutes)
CACHE_TTL=900

# UK_PROXY_URL is NOT required — BBC audio streams and APIs work from US IPs.
# The geo-restriction only applies to the BBC Sounds web player UI, not the CDN or APIs.
# Leave this unset.
# UK_PROXY_URL=
